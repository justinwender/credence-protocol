# =============================================================================
# Credence Protocol — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitignore).
# =============================================================================

# --- Allium ---
# Optional — Allium API key for live blockchain data queries.
# Without this key, the scoring pipeline works in demo mode:
#   - Pre-cached real wallet data for known addresses (from demo_wallets.json)
#   - Deterministic synthetic profiles for unknown addresses
# With this key, the pipeline queries live blockchain data across 5 chains (~90 seconds per score).
# Get a key at https://app.allium.so
ALLIUM_API_KEY=

# --- BSC Testnet (Phase 4+) ---
# Generate a fresh wallet for testnet only. NEVER use a mainnet private key.
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_TESTNET_PRIVATE_KEY=
# Etherscan V2 API key (works across all chains including BscScan — same key)
ETHERSCAN_API_KEY=

# --- Deployed Contract Addresses (populated after Phase 4 deployment) ---
ATTESTATION_REGISTRY_ADDRESS=
CREDIT_ORACLE_ADDRESS=
LENDING_POOL_ADDRESS=
